<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E27">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Звёзды и космос"
            android:textColor="#FFD700"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Космос — это бескрайнее пространство, наполненное звёздами, планетами, галактиками и туманностями. Каждая звезда — это далёкое солнце, вокруг которого могут вращаться свои миры."
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#3355FF"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Интересные факты"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• В Млечном Пути около 100 миллиардов звёзд\n• Ближайшая звезда — Проксима Центавра (4,24 световых года)\n• Нейтронные звёзды могут вращаться до 600 раз в секунду\n• Звезды рождаются в туманностях из газа и пыли"
            android:textColor="#E0E0E0"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>